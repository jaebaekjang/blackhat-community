# 검은 모자 라디오국 - 환경 변수 예시
# 이 파일을 .env.local 로 복사해서 사용하세요. (cp .env.example .env.local)

# YouTube 채널 ID (검은 모자 공포라디오)
# RSS 피드와 홈 화면 최신 영상 섹션에서 사용됩니다.
YOUTUBE_CHANNEL_ID=UCSF-jV2STm5g66JlHBh6MWg

# (선택) YouTube Data API Key
# 비워두면 RSS 피드 -> mock 순으로 fallback 동작합니다.
YOUTUBE_API_KEY=

# (선택) Uploads Playlist ID — YouTube Data API 확장 시 사용
YOUTUBE_UPLOADS_PLAYLIST_ID=
